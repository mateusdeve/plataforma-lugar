# ─────────────────────────────────────────────────────────────────────────────
# PADRÕES DE DESENVOLVIMENTO — versionado de propósito.
#
# É convenção do Symfony e é o que faz `docker compose up` funcionar num clone
# limpo (requisito do PRD §14): quem clona não precisa adivinhar quais
# variáveis existem.
#
# NADA DE SEGREDO REAL AQUI. Em produção cada valor é sobrescrito por variável
# de ambiente no EasyPanel; localmente, sobrescreva em `.env.local`, que é
# ignorado pelo git. Variável de ambiente real sempre vence este arquivo.
#
# Os blocos ###> ... ###< que os recipes do Flex acrescentam foram removidos:
# eles redeclaravam APP_SECRET (vazio) e DATABASE_URL (com credencial de
# exemplo), e a ÚLTIMA declaração é a que vale — o que silenciosamente anulava
# a configuração real.
# ─────────────────────────────────────────────────────────────────────────────

APP_ENV=dev
APP_DEBUG=1

# Chave de desenvolvimento. Se este valor aparecer em produção, é bug de
# deploy — não configuração.
APP_SECRET=dev_apenas_nao_use_em_producao

# O host `banco` é o nome do serviço no docker-compose, resolvido pela rede
# interna do Docker. O Postgres não expõe porta pública (PRD §7.3).
DATABASE_URL="postgresql://lugar:lugar@banco:5432/lugar?serverVersion=16&charset=utf8"

MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=true

# Origem autorizada no CORS. Em produção: https://comprarbem.store
CORS_ORIGEM_PERMITIDA=http://localhost:3000

DEFAULT_URI=http://localhost:8000

# ── autenticação (ADR-004) ───────────────────────────────────────────────
# As chaves .pem ficam em config/jwt/ e NÃO são versionadas. Gere as suas:
#   docker compose exec api php bin/console lexik:jwt:generate-keypair
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=dev_apenas_nao_use_em_producao

# Access token curto de propósito: se vazar, a janela de uso é pequena. A
# sessão longa vive no refresh token, que é rotacionado a cada uso e revogável.
JWT_TTL_SEGUNDOS=900
REFRESH_TTL_DIAS=30
