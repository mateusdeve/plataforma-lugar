{
    "name": "lugar/api",
    "description": "API da plataforma lugar. — venda de ingressos com reserva temporária",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.4",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "doctrine/dbal": "^4.2",
        "doctrine/doctrine-bundle": "^3.2",
        "doctrine/doctrine-migrations-bundle": "^4.0",
        "doctrine/orm": "^3.3",
        "symfony/console": "8.1.*",
        "symfony/dotenv": "8.1.*",
        "symfony/flex": "^2",
        "symfony/framework-bundle": "8.1.*",
        "symfony/messenger": "8.1.*",
        "symfony/doctrine-messenger": "8.1.*",
        "symfony/runtime": "8.1.*",
        "symfony/uid": "8.1.*",
        "symfony/yaml": "8.1.*"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^11.5",
        "qossmic/deptrac": "^2.0",
        "symfony/phpunit-bridge": "8.1.*"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true,
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "Lugar\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Lugar\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "stan": "phpstan analyse",
        "camadas": "deptrac analyse --fail-on-uncovered --report-uncovered",
        "check": [
            "@stan",
            "@camadas",
            "@test"
        ],
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd"
        }
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "8.1.*",
            "docker": false
        }
    }
}
